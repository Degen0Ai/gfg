<script>
// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
let S = {
  runs:[],checkins:[],sleepLog:[],bodyMetrics:[],injuries:[],gear:[],
  foodLog:[],scanHistory:[],
  nutrition:{cal:0,prot:0,carb:0,fat:0,fiber:0,sugar:0,sodium:0,water:0},
  nutritionDate:'',
  profile:{},apiKey:'',
  chatHistory:[],
  trainingPlan:null,
  currentScan:null
};

// ═══════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  loadState();
  document.getElementById('l-date').value=today();
  document.getElementById('datePill').textContent=new Date().toLocaleDateString('en',{month:'short',day:'numeric'});
  loadProfile();
  renderAll();
  buildClassicWorkouts();
  buildHydrationCups();
  setTimeout(drawAllCharts,100);
  resetNutritionIfNewDay();
});

function loadState(){
  try{const d=localStorage.getItem('apex_v3');if(d)S={...S,...JSON.parse(d)};}catch(e){}
}
function saveState(){try{localStorage.setItem('apex_v3',JSON.stringify(S));}catch(e){}}
function today(){return new Date().toISOString().split('T')[0];}
function toast(msg,ms=2200){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),ms);}

function resetNutritionIfNewDay(){
  if(S.nutritionDate!==today()){
    S.nutrition={cal:0,prot:0,carb:0,fat:0,fiber:0,sugar:0,sodium:0,water:S.nutrition.water||0};
    S.nutritionDate=today();
    S.foodLog=S.foodLog||[];
    saveState();
  }
}

// ═══════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════
function nav(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.bn').forEach(b=>b.classList.remove('active'));
  const pg=document.getElementById('page-'+id);
  if(pg)pg.classList.add('active');
  document.querySelectorAll('.bn').forEach(b=>{
    if(b.getAttribute('onclick')&&b.getAttribute('onclick').includes("'"+id+"'"))b.classList.add('active');
  });
  if(id==='progress')renderProgress();
  if(id==='training')renderTraining();
  if(id==='home')renderAll();
}

// ═══════════════════════════════════════════════════
// TAB HELPERS
// ═══════════════════════════════════════════════════
function logTab(t){
  ['run','checkin','sleep','nutrition','body'].forEach(x=>{
    document.getElementById('lt-'+x).style.display=x===t?'block':'none';
  });
  document.querySelectorAll('#logTabBar .tab').forEach((b,i)=>{
    b.classList.toggle('active',['run','checkin','sleep','nutrition','body'][i]===t);
  });
  if(t==='nutrition')renderNutrition();
  if(t==='sleep')renderSleepHist();
  if(t==='checkin')renderCiHistory();
  if(t==='body')renderInjuries();
}
function trainTab(t){
  ['plan','zones','race','gear','intervals'].forEach(x=>{
    const el=document.getElementById('tt-'+x);if(el)el.style.display=x===t?'block':'none';
  });
  document.querySelectorAll('#page-training .tab').forEach((b,i)=>{
    b.classList.toggle('active',['plan','zones','race','gear','intervals'][i]===t);
  });
  if(t==='zones'){calcZones();renderVO2();}
  if(t==='race'){renderPBs();}
  if(t==='gear')renderGear();
  if(t==='intervals')buildClassicWorkouts();
}
function progTab(t){
  ['runs','trends','body','recovery'].forEach(x=>{
    const el=document.getElementById('pt-'+x);if(el)el.style.display=x===t?'block':'none';
  });
  document.querySelectorAll('#page-progress .tab').forEach((b,i)=>{
    b.classList.toggle('active',['runs','trends','body','recovery'][i]===t);
  });
  if(t==='trends'){setTimeout(()=>{drawTrendCharts();renderStatsSummary();},50);}
  if(t==='body'){setTimeout(()=>drawWeightChart(),50);renderBodyMetricsLog();}
  if(t==='recovery')renderRecovery();
}
function sliderLbl(id,lbl,opts){
  const v=parseInt(document.getElementById(id).value)-1;
  document.getElementById(lbl).textContent=opts[v]||v+1;
}

// ═══════════════════════════════════════════════════
// RENDER ALL (home)
// ═══════════════════════════════════════════════════
function renderAll(){
  renderHomeStats();
  renderRecentRuns();
  renderStreak();
  renderTodaySession();
  renderWeekDots();
  updateStreakPill();
  drawWeeklyChart();
}

function renderHomeStats(){
  const wkRuns=weekRuns();
  const wkKm=wkRuns.reduce((s,r)=>s+r.dist,0);
  const totalKm=S.runs.reduce((s,r)=>s+r.dist,0);

  set('h-wkm',wkKm.toFixed(1)+'<span class="su">km</span>');
  set('h-total',S.runs.length);
  set('h-totalkm',totalKm.toFixed(1)+' km all time');

  if(wkRuns.length){
    const avgPace=wkRuns.reduce((s,r)=>s+paceSecs(r.dist,r.time),0)/wkRuns.length;
    set('h-pace',fmtPace(avgPace)+'<span class="su">/km</span>');
  }

  const load=Math.round(wkRuns.reduce((s,r)=>s+(r.dist*(parseInt(r.rpe)||5)*3.5),0));
  set('h-load',load||'—');

  const ci=S.checkins[0];
  if(ci){
    const r=readiness(ci);
    set('h-ready',r+'<span class="su">%</span>');
    const rdEl=document.getElementById('h-ready-d');
    rdEl.textContent=r>=70?'Ready to run':r>=40?'Moderate':'Rest today';
    rdEl.className='sd '+(r>=70?'up':r>=40?'nt':'dn');
  }

  renderVO2();
}

function weekRuns(){
  const mon=new Date();mon.setDate(mon.getDate()-((mon.getDay()+6)%7));mon.setHours(0,0,0,0);
  return S.runs.filter(r=>new Date(r.date)>=mon);
}

function readiness(ci){
  const e=parseInt(ci.energy)||3,m=parseInt(ci.mood)||3,s=parseInt(ci.stress)||3;
  return Math.round(((e+m+(6-s))/15)*100);
}

function renderVO2(){
  const runs=S.runs.filter(r=>r.hr>0);
  if(!runs.length)return;
  const best=runs.sort((a,b)=>b.dist-a.dist)[0];
  const ps=paceSecs(best.dist,best.time);
  const spd=3600/ps;
  const vo2=Math.round((-4.6+1.01*spd)*3.5);
  const v=Math.max(25,Math.min(85,vo2));
  set('h-vo2',v);
  set('h-vo2-d',voLabel(v).tier);

  // gauge
  const gaugeEl=document.getElementById('gaugeVal');
  if(gaugeEl){gaugeEl.textContent=v;document.getElementById('gaugeTier').textContent=voLabel(v).tier;document.getElementById('gaugeDesc').textContent=voLabel(v).desc;}
  const fill=document.getElementById('gaugeFill');
  if(fill){const pct=(v-20)/(85-20);const offset=188-(188*pct);fill.style.strokeDashoffset=offset;}
}

function voLabel(v){
  if(v<35)return{tier:'Below Average',desc:'Focus on aerobic base building'};
  if(v<45)return{tier:'Average',desc:'Consistent training will improve this fast'};
  if(v<55)return{tier:'Good',desc:'Strong aerobic fitness for a runner'};
  if(v<65)return{tier:'Excellent',desc:'Elite recreational level'};
  return{tier:'Superior',desc:'Elite / competitive athlete level'};
}

function renderRecentRuns(){
  const el=document.getElementById('recentHome');
  const runs=S.runs.slice(0,5);
  if(!runs.length){el.innerHTML='<div class="empty-s">Log your first run in the Log tab</div>';return;}
  el.innerHTML=runs.map(r=>`
    <div class="rrow">
      <div class="rrow-l"><div class="rrow-type">${r.type}</div><div class="rrow-date">${r.date} · ${r.surface||'Road'}</div></div>
      <div class="rrow-r"><div class="rrow-dist">${r.dist}<span style="font-size:12px;color:var(--mt2)">km</span></div><div class="rrow-pace">${r.pace}/km · ${r.time}</div></div>
    </div>`).join('');
}

function renderStreak(){
  const el=document.getElementById('streakGrid');
  const cells=[];
  for(let i=27;i>=0;i--){
    const d=new Date();d.setDate(d.getDate()-i);
    const ds=d.toISOString().split('T')[0];
    const hasRun=S.runs.some(r=>r.date===ds);
    const isToday=i===0;
    cells.push(`<div class="sd-cell ${hasRun?'sd-run':'sd-rest'} ${isToday?'sd-today':''}">${d.getDate()}</div>`);
  }
  el.innerHTML=cells.join('');
}

function updateStreakPill(){
  let streak=0,d=new Date();
  while(true){
    const ds=d.toISOString().split('T')[0];
    if(S.runs.some(r=>r.date===ds)){streak++;d.setDate(d.getDate()-1);}else break;
  }
  document.getElementById('streakPill').textContent=streak+' day streak';
}

function renderTodaySession(){
  const el=document.getElementById('todaySess');
  if(!S.trainingPlan){el.innerHTML='<div class="empty-s">No plan yet — ask Coach or generate one in Training</div>';return;}
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const day=days[new Date().getDay()];
  const w=S.trainingPlan[day];
  if(!w){el.innerHTML='<div class="empty-s">Rest day today</div>';return;}
  el.innerHTML=`<div class="wcard"><div class="wcard-stripe" style="background:var(--r)"></div><div class="wcard-day">${day}</div><div class="wcard-type">${w.type}</div><div class="wcard-det">${w.detail}</div><span class="badge badge-r">${w.zone||'Zone 2'}</span></div>`;
}

function renderWeekDots(){
  const el=document.getElementById('weekDots');
  if(!el)return;
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const dayIdx=[1,2,3,4,5,6,0];
  const today=new Date().getDay();
  el.innerHTML=days.map((d,i)=>{
    const ti=dayIdx[i];
    const dt=new Date();dt.setDate(dt.getDate()-(((today-ti)+7)%7));
    const ds=dt.toISOString().split('T')[0];
    const hasRun=S.runs.some(r=>r.date===ds);
    const isToday=ti===today;
    return `<div class="wd"><div class="wd-dot ${hasRun?'has':''} ${isToday?'today':''}">${hasRun?'✓':'·'}</div><div class="wd-name">${d}</div></div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════
// LOG RUN
// ═══════════════════════════════════════════════════
async function logRun(analyze=true){
  const dist=parseFloat(document.getElementById('l-dist').value);
  const time=document.getElementById('l-time').value;
  if(!dist||!time){toast('Distance and time required');return;}

  const run={
    id:Date.now(),
    date:document.getElementById('l-date').value||today(),
    type:document.getElementById('l-type').value,
    dist,time,
    hr:parseInt(document.getElementById('l-hr').value)||0,
    maxhr:parseInt(document.getElementById('l-maxhr').value)||0,
    cad:parseInt(document.getElementById('l-cad').value)||0,
    elev:parseInt(document.getElementById('l-elev').value)||0,
    temp:parseInt(document.getElementById('l-temp').value)||0,
    humid:parseInt(document.getElementById('l-humid').value)||0,
    surface:document.getElementById('l-surface').value,
    shoes:document.getElementById('l-shoes').value,
    rpe:document.getElementById('l-rpe').value,
    notes:document.getElementById('l-notes').value,
    pace:fmtPace(paceSecs(dist,time))
  };
  S.runs.unshift(run);
  updateGearKm(run.shoes,dist);
  saveState();
  renderAll();
  toast('Run saved ✓');
  document.getElementById('logStatus').textContent='Saved '+run.dist+'km '+run.type;

  if(analyze&&S.apiKey){
    nav('coach');
    await analyzeRun(run);
  } else if(analyze&&!S.apiKey){
    toast('Add API key in Tools → Profile to get AI analysis');
  }
}

// ═══════════════════════════════════════════════════
// CHECK-IN
// ═══════════════════════════════════════════════════
function saveCheckin(){
  S.checkins.unshift({
    date:new Date().toISOString(),
    mood:document.getElementById('ci-mood').value,
    energy:document.getElementById('ci-energy').value,
    stress:document.getElementById('ci-stress').value,
    motiv:document.getElementById('ci-motiv').value,
    soreness:document.getElementById('ci-sor').value,
    legs:document.getElementById('ci-legs').value,
    pain:document.getElementById('ci-pain').value,
    appetite:document.getElementById('ci-app').value,
    notes:document.getElementById('ci-notes').value
  });
  saveState();renderAll();renderCiHistory();renderRecovery();
  toast('Check-in saved ✓');
}
function renderCiHistory(){
  const el=document.getElementById('ciHistory');
  if(!S.checkins.length){el.innerHTML='<div class="empty-s">No check-ins yet</div>';return;}
  el.innerHTML=S.checkins.slice(0,7).map(c=>{
    const dt=new Date(c.date).toLocaleDateString('en',{month:'short',day:'numeric'});
    return `<div class="ci-row"><div><div style="font-size:13px;color:var(--wh);">${dt}</div><div class="ci-date">${c.soreness} soreness · ${c.legs} legs</div></div><div class="ci-pills"><span class="badge badge-b">M:${c.mood}</span><span class="badge badge-g">E:${c.energy}</span><span class="badge badge-o">S:${c.stress}</span></div></div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════
// SLEEP
// ═══════════════════════════════════════════════════
function saveSleep(){
  const bed=document.getElementById('sl-bed').value;
  const wake=document.getElementById('sl-wake').value;
  let hrs=0;
  if(bed&&wake){
    const bm=parseInt(bed.split(':')[0])*60+parseInt(bed.split(':')[1]);
    const wm=parseInt(wake.split(':')[0])*60+parseInt(wake.split(':')[1]);
    hrs=((wm<bm?wm+1440:wm)-bm)/60;
  }
  S.sleepLog.unshift({date:today(),bed,wake,hrs:hrs.toFixed(1),quality:document.getElementById('sl-qual').value,hrv:document.getElementById('sl-hrv').value,rhr:document.getElementById('sl-rhr').value,notes:document.getElementById('sl-notes').value});
  saveState();renderSleepHist();renderRecovery();toast('Sleep logged ✓');
}
function renderSleepHist(){
  const el=document.getElementById('sleepHist');
  if(!S.sleepLog.length){el.innerHTML='<div class="empty-s">No sleep data yet</div>';return;}
  el.innerHTML=S.sleepLog.slice(0,7).map(s=>{
    const q=parseInt(s.quality)||3;const qColor=q>=4?'var(--gn)':q>=3?'var(--or)':'var(--r)';
    return `<div class="sleep-row"><div><div class="sleep-hrs">${s.hrs}h</div><div style="font-family:var(--mono);font-size:9px;color:var(--mt2);">${s.bed||'—'} → ${s.wake||'—'}</div></div><div style="text-align:right"><div class="sleep-qual" style="color:${qColor}">${['','Terrible','Poor','OK','Good','Excellent'][q]}</div><div style="font-family:var(--mono);font-size:9px;color:var(--mt2);">${s.date}${s.hrv?' · HRV '+s.hrv:''}${s.rhr?' · RHR '+s.rhr:''}</div></div></div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════
// BODY METRICS + INJURIES
// ═══════════════════════════════════════════════════
function saveBodyMetrics(){
  S.bodyMetrics.unshift({date:today(),weight:document.getElementById('bm-wt').value,bf:document.getElementById('bm-bf').value,rhr:document.getElementById('bm-rhr').value,bp:document.getElementById('bm-bp').value,waist:document.getElementById('bm-waist').value,legf:document.getElementById('bm-legf').value,notes:document.getElementById('bm-notes').value});
  saveState();toast('Body metrics saved ✓');renderBodyMetricsLog();
}
function renderBodyMetricsLog(){
  const el=document.getElementById('bodyMetricsLog');
  if(!S.bodyMetrics.length){el.innerHTML='<div class="empty-s">No body data logged yet</div>';return;}
  el.innerHTML=S.bodyMetrics.slice(0,10).map(m=>`
    <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;">
      <div><div style="color:var(--wh);font-weight:500;">${m.date}</div><div style="font-family:var(--mono);font-size:9px;color:var(--mt2);">${m.bp?'BP '+m.bp+' · ':''} ${m.waist?'Waist '+m.waist+'cm':''}</div></div>
      <div style="text-align:right"><div style="font-family:var(--font);font-size:18px;font-weight:700;color:var(--wh);">${m.weight||'—'}<span style="font-size:11px;color:var(--mt2)">kg</span></div><div style="font-family:var(--mono);font-size:9px;color:var(--mt2);">${m.bf?m.bf+'% bf':''}</div></div>
    </div>`).join('');
}
function saveInjury(){
  S.injuries.unshift({date:today(),part:document.getElementById('inj-part').value,sev:document.getElementById('inj-sev').value,type:document.getElementById('inj-type').value,when:document.getElementById('inj-when').value,desc:document.getElementById('inj-desc').value});
  saveState();renderInjuries();toast('Injury logged');
}
function renderInjuries(){
  const el=document.getElementById('injList');
  if(!S.injuries.length){el.innerHTML='<div class="empty-s">No injuries logged</div>';return;}
  el.innerHTML=S.injuries.slice(0,5).map(i=>`<div class="inj-row"><div class="inj-part">${i.part} — ${i.type}</div><div class="inj-detail">Severity ${i.sev}/10 · ${i.when} · ${i.date}${i.desc?' · '+i.desc:''}</div></div>`).join('');
}

// ═══════════════════════════════════════════════════
// NUTRITION
// ═══════════════════════════════════════════════════
function addFood(foodData){
  const d=foodData||{
    name:document.getElementById('nf-name').value||'Food item',
    cal:parseFloat(document.getElementById('nf-cal').value)||0,
    prot:parseFloat(document.getElementById('nf-prot').value)||0,
    carb:parseFloat(document.getElementById('nf-carb').value)||0,
    fat:parseFloat(document.getElementById('nf-fat').value)||0,
    fiber:parseFloat(document.getElementById('nf-fiber').value)||0,
    sugar:parseFloat(document.getElementById('nf-sugar').value)||0,
    sodium:parseFloat(document.getElementById('nf-sodium').value)||0,
    meal:document.getElementById('nf-meal').value,
    time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})
  };
  S.foodLog.push(d);
  S.nutrition.cal+=d.cal;S.nutrition.prot+=d.prot;S.nutrition.carb+=d.carb;
  S.nutrition.fat+=d.fat;S.nutrition.fiber+=d.fiber;S.nutrition.sugar+=d.sugar;
  S.nutrition.sodium+=d.sodium;
  saveState();renderNutrition();toast('Food added ✓');
}

function renderNutrition(){
  const n=S.nutrition;
  const p=S.profile;
  const calGoal=parseInt(p.calgoal)||2200;
