function drawWeeklyChart(){
  const canvas=document.getElementById('weekChart');if(!canvas)return;
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth||300;canvas.height=90;
  const weeks=[];
  for(let i=7;i>=0;i--){
    const d=new Date();d.setDate(d.getDate()-i*7);
    const start=new Date(d);start.setDate(start.getDate()-(start.getDay()+6)%7);
    const end=new Date(start);end.setDate(end.getDate()+6);
    weeks.push(S.runs.filter(r=>{const rd=new Date(r.date);return rd>=start&&rd<=end;}).reduce((s,r)=>s+r.dist,0));
  }
  drawBarChart(ctx,weeks,canvas.width,canvas.height);
}

function drawBarChart(ctx,data,w,h,color='#E8380D'){
  const max=Math.max(...data,1);
  const bw=(w/data.length)*0.55;const gap=(w/data.length)*0.45;
  ctx.clearRect(0,0,w,h);
  data.forEach((v,i)=>{
    const x=i*(bw+gap)+gap/2;const bh=(v/max)*(h-18);const y=h-18-bh;
    ctx.fillStyle=i===data.length-1?color:'#2a2a2a';
    ctx.fillRect(x,y,bw,bh);
    if(v>0){ctx.fillStyle=i===data.length-1?'#fff':'#555';ctx.font='8px DM Mono, monospace';ctx.textAlign='center';ctx.fillText(v.toFixed(0),x+bw/2,y-3);}
    ctx.fillStyle='#444';ctx.font='7px DM Mono, monospace';ctx.textAlign='center';ctx.fillText(i===data.length-1?'NOW':'W-'+(7-i),x+bw/2,h-2);
  });
}

