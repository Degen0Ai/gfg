function calcZones(){
  const max=parseInt(document.getElementById('z-max').value)||(parseInt(document.getElementById('z-age').value)?220-parseInt(document.getElementById('z-age').value):0);
  const rest=parseInt(document.getElementById('z-rest').value)||0;
  const method=document.getElementById('z-method').value;
  if(!max)return;
  const z=(lo,hi)=>{
    if(method==='karv'&&rest){
      return`${Math.round(rest+(max-rest)*lo)}–${Math.round(rest+(max-rest)*hi)} bpm`;
    }
    return`${Math.round(max*lo)}–${Math.round(max*hi)} bpm`;
  };
  document.getElementById('z1').textContent=z(.50,.60);
  document.getElementById('z2').textContent=z(.60,.70);
  document.getElementById('z3').textContent=z(.70,.80);
  document.getElementById('z4').textContent=z(.80,.90);
  document.getElementById('z5').textContent=z(.90,1.0);
}

