<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#080808">
<title>APEX — Running Coach</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,700;1,900&family=Barlow:wght@300;400;500;600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --r:#E8380D;--r2:#c42e09;--r3:rgba(232,56,13,0.1);
  --bk:#080808;--d1:#111;--d2:#181818;--d3:#222;--d4:#2a2a2a;
  --br:#252525;--br2:#303030;
  --mt:#4a4a4a;--mt2:#666;--mt3:#999;
  --tx:#c8c8c8;--wh:#f0f0f0;
  --gn:#2ecc71;--or:#f0a500;--bl:#4a9eff;--pu:#9b59b6;
  --font:'Barlow Condensed',sans-serif;
  --body:'Barlow',sans-serif;
  --mono:'DM Mono',monospace;
  --sb:env(safe-area-inset-bottom,0px);
  --st:env(safe-area-inset-top,0px);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;background:var(--bk);overscroll-behavior:none;}
body{font-family:var(--body);font-weight:300;color:var(--tx);}

/* ─── SHELL ─── */
#app{display:flex;flex-direction:column;height:100vh;height:100dvh;}
#topbar{
  flex-shrink:0;height:56px;
  background:rgba(8,8,8,0.97);border-bottom:1px solid var(--br);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;z-index:60;position:relative;
}
.logo{font-family:var(--font);font-size:22px;font-weight:900;letter-spacing:.2em;color:var(--wh);}
.logo span{color:var(--r);}
#topbar-meta{display:flex;gap:8px;align-items:center;}
.meta-pill{font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;padding:4px 9px;border:1px solid var(--br);border-radius:1px;color:var(--mt2);}
.meta-pill.live{border-color:rgba(46,204,113,.35);color:var(--gn);}

#pages{flex:1;overflow:hidden;position:relative;}
.page{position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;display:none;padding-bottom:calc(68px + var(--sb));}
.page.active{display:block;}
.page::-webkit-scrollbar{display:none;}

/* BOTTOM NAV */
#bnav{
  flex-shrink:0;height:calc(60px + var(--sb));padding-bottom:var(--sb);
  background:rgba(9,9,9,.98);border-top:1px solid var(--br);
  display:grid;grid-template-columns:repeat(6,1fr);z-index:60;
}
.bn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;padding:6px 0;border:none;background:none;transition:all .15s;}
.bn-ic{font-size:19px;line-height:1;color:var(--mt);transition:all .15s;}
.bn-lb{font-family:var(--mono);font-size:7px;letter-spacing:.07em;text-transform:uppercase;color:var(--mt);transition:color .15s;}
.bn.active .bn-ic{color:var(--r);}
.bn.active .bn-lb{color:var(--r);}

/* ─── LAYOUT PRIMITIVES ─── */
.sec{padding:18px 16px;border-bottom:1px solid var(--br);}
.sec-last{border-bottom:none;}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.sh-t{font-family:var(--font);font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--wh);}
.sh-a{font-family:var(--mono);font-size:9px;color:var(--r);letter-spacing:.1em;text-transform:uppercase;background:none;border:none;cursor:pointer;}
.divl{height:1px;background:var(--br);margin:14px 0;}
.empty-s{color:var(--mt2);font-size:12px;font-style:italic;padding:4px 0;}

/* HERO */
.hero{position:relative;min-height:150px;overflow:hidden;background:var(--d2);display:flex;align-items:flex-end;padding:20px 16px;}
.hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,rgba(232,56,13,.16) 0%,transparent 55%),repeating-linear-gradient(-45deg,transparent,transparent 30px,rgba(232,56,13,.025) 30px,rgba(232,56,13,.025) 31px);}
.hero-grid{position:absolute;inset:0;background:repeating-linear-gradient(90deg,transparent,transparent 40px,rgba(255,255,255,.01) 40px,rgba(255,255,255,.01) 41px);}
.hero-letter{position:absolute;right:-8px;top:50%;transform:translateY(-50%);font-family:var(--font);font-size:160px;font-weight:900;font-style:italic;color:var(--r);opacity:.055;line-height:1;user-select:none;pointer-events:none;}
.hero-content{position:relative;z-index:1;}
.hero-eye{font-family:var(--mono);font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:var(--r);margin-bottom:7px;}
.hero-ttl{font-family:var(--font);font-size:44px;font-weight:900;line-height:.88;color:var(--wh);text-transform:uppercase;}
.hero-ttl em{font-style:italic;color:var(--r);}
.hero-sub{margin-top:8px;font-size:11px;color:var(--mt2);letter-spacing:.04em;}

/* STAT GRID */
.sg{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--br);}
.sc{background:var(--d1);padding:14px 15px;}
.sc-w{grid-column:span 2;}
.sl{font-family:var(--mono);font-size:8px;letter-spacing:.15em;text-transform:uppercase;color:var(--mt2);margin-bottom:4px;}
.sv{font-family:var(--font);font-size:28px;font-weight:800;color:var(--wh);line-height:1;}
.su{font-size:12px;font-weight:400;color:var(--mt2);margin-left:2px;}
.sd{font-family:var(--mono);font-size:8px;margin-top:2px;}
.up{color:var(--gn);}.dn{color:var(--r);}.nt{color:var(--mt2);}

/* CARDS */
.card{background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:14px;}
.card+.card{margin-top:8px;}

/* FORMS */
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.fg1{display:grid;grid-template-columns:1fr;gap:10px;}
.fg{display:flex;flex-direction:column;gap:4px;}
.fg.s2{grid-column:1/-1;}
.fg label{font-family:var(--mono);font-size:8px;letter-spacing:.15em;text-transform:uppercase;color:var(--mt2);}
.fi{background:var(--d3);border:1px solid var(--br);color:var(--wh);font-family:var(--body);font-size:13px;padding:10px 12px;border-radius:2px;outline:none;-webkit-appearance:none;appearance:none;transition:border-color .15s;width:100%;}
.fi:focus{border-color:var(--r);}
.fi::placeholder{color:var(--mt);}
textarea.fi{resize:vertical;min-height:60px;}

/* BUTTONS */
.btn{width:100%;padding:14px;border:none;cursor:pointer;border-radius:2px;font-family:var(--font);font-size:14px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-r{background:var(--r);color:#fff;}
.btn-r:active{background:var(--r2);transform:scale(.98);}
.btn-r:disabled{background:var(--d3);color:var(--mt);cursor:not-allowed;}
.btn-g{background:transparent;color:var(--mt2);border:1px solid var(--br);font-size:12px;padding:10px;}
.btn-g:active{color:var(--wh);border-color:var(--br2);}
.btn-sm{padding:8px 14px;font-size:11px;width:auto;}
.brow{display:flex;gap:10px;margin-top:12px;}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--br);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:11px 16px;font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;color:var(--mt2);transition:all .15s;background:none;border-top:none;border-left:none;border-right:none;white-space:nowrap;flex-shrink:0;}
.tab.active{color:var(--wh);border-bottom-color:var(--r);}

/* CHART */
.chart-wrap{height:90px;position:relative;}
canvas{display:block;}

/* RANGE SLIDER */
input[type=range]{width:100%;height:3px;-webkit-appearance:none;appearance:none;background:var(--d3);border-radius:2px;outline:none;margin-top:8px;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--r);cursor:pointer;}
.slab{display:flex;justify-content:space-between;font-family:var(--mono);font-size:8px;color:var(--mt);margin-top:3px;}

/* METRIC BARS */
.mb-row{margin-bottom:10px;}
.mb-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.mb-name{font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;color:var(--mt2);}
.mb-val{font-family:var(--mono);font-size:11px;color:var(--wh);}
.mb{height:4px;background:var(--d3);border-radius:2px;overflow:hidden;}
.mb-fill{height:100%;border-radius:2px;transition:width .7s cubic-bezier(.4,0,.2,1);}

/* ZONES */
.zone-row{display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;}
.zone-row::-webkit-scrollbar{display:none;}
.zc{flex-shrink:0;width:76px;background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:11px 8px;text-align:center;}
.zn{font-family:var(--font);font-size:22px;font-weight:800;line-height:1;}
.zl{font-family:var(--mono);font-size:7px;letter-spacing:.08em;text-transform:uppercase;color:var(--mt2);margin:3px 0;}
.zb{font-family:var(--mono);font-size:8px;color:var(--mt);}
.z1c{color:#4a9eff;}.z2c{color:#2ecc71;}.z3c{color:#f0a500;}.z4c{color:#ff6b35;}.z5c{color:var(--r);}

/* RUN ROWS */
.rrow{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.rrow:last-child{border-bottom:none;}
.rrow-l{}
.rrow-type{font-size:13px;font-weight:500;color:var(--wh);}
.rrow-date{font-family:var(--mono);font-size:9px;color:var(--mt2);margin-top:2px;}
.rrow-r{text-align:right;}
.rrow-dist{font-family:var(--font);font-size:18px;font-weight:800;color:var(--wh);line-height:1;}
.rrow-pace{font-family:var(--mono);font-size:9px;color:var(--gn);margin-top:2px;}

/* STREAK */
.streak-g{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;}
.sd-cell{aspect-ratio:1;border-radius:2px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:7px;cursor:default;}
.sd-empty{background:var(--d3);color:var(--mt);}
.sd-run{background:var(--r);color:#fff;}
.sd-rest{background:var(--d2);border:1px solid var(--br);color:var(--mt2);}
.sd-today{outline:1px solid var(--wh);outline-offset:1px;}

/* WORKOUT CARD */
.wcard{background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:14px;margin-bottom:8px;position:relative;overflow:hidden;}
.wcard-stripe{position:absolute;left:0;top:0;bottom:0;width:3px;}
.wcard-day{font-family:var(--mono);font-size:8px;letter-spacing:.15em;text-transform:uppercase;color:var(--mt2);margin-bottom:5px;padding-left:12px;}
.wcard-type{font-family:var(--font);font-size:19px;font-weight:800;color:var(--wh);padding-left:12px;line-height:1;}
.wcard-det{font-size:11px;color:var(--mt2);margin-top:5px;padding-left:12px;line-height:1.5;}
.badge{display:inline-block;font-family:var(--mono);font-size:7px;letter-spacing:.1em;text-transform:uppercase;padding:3px 7px;border-radius:1px;margin-top:8px;margin-left:12px;}
.badge-r{background:rgba(232,56,13,.1);color:var(--r);border:1px solid rgba(232,56,13,.2);}
.badge-g{background:rgba(46,204,113,.08);color:var(--gn);border:1px solid rgba(46,204,113,.18);}
.badge-o{background:rgba(240,165,0,.08);color:var(--or);border:1px solid rgba(240,165,0,.18);}
.badge-b{background:rgba(74,158,255,.08);color:var(--bl);border:1px solid rgba(74,158,255,.18);}

/* TOOL CARDS */
.tool-g{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.tc{background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:14px;cursor:pointer;transition:border-color .15s;display:flex;flex-direction:column;gap:5px;}
.tc:active{border-color:var(--br2);transform:scale(.98);}
.tc-ic{font-size:20px;line-height:1;}
.tc-name{font-family:var(--font);font-size:14px;font-weight:700;color:var(--wh);}
.tc-desc{font-family:var(--mono);font-size:7px;color:var(--mt2);letter-spacing:.04em;line-height:1.4;}

/* ─── AI FOOD SCANNER ─── */
#scannerPage{display:none;position:fixed;inset:0;z-index:200;background:var(--bk);flex-direction:column;}
#scannerPage.open{display:flex;}
.scan-top{display:flex;align-items:center;justify-content:space-between;padding:16px 16px 0;flex-shrink:0;}
.scan-title{font-family:var(--font);font-size:18px;font-weight:900;letter-spacing:.15em;text-transform:uppercase;color:var(--wh);}
.scan-close{background:var(--d2);border:1px solid var(--br);color:var(--wh);width:36px;height:36px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;}

/* CAMERA VIEWFINDER */
.cam-wrap{flex:1;position:relative;overflow:hidden;background:#000;margin:16px;border-radius:4px;}
#camFeed{width:100%;height:100%;object-fit:cover;display:block;}
.cam-overlay{position:absolute;inset:0;pointer-events:none;}
.cam-corners{position:absolute;inset:16px;}
.cam-corner{position:absolute;width:24px;height:24px;}
.cam-corner.tl{top:0;left:0;border-top:2px solid var(--r);border-left:2px solid var(--r);}
.cam-corner.tr{top:0;right:0;border-top:2px solid var(--r);border-right:2px solid var(--r);}
.cam-corner.bl{bottom:0;left:0;border-bottom:2px solid var(--r);border-left:2px solid var(--r);}
.cam-corner.br{bottom:0;right:0;border-bottom:2px solid var(--r);border-right:2px solid var(--r);}
.cam-scan-line{position:absolute;left:16px;right:16px;height:1px;background:linear-gradient(90deg,transparent,var(--r),transparent);animation:scanLine 2.5s ease-in-out infinite;}
@keyframes scanLine{0%{top:16px;opacity:0;}10%{opacity:1;}90%{opacity:1;}100%{top:calc(100% - 16px);opacity:0;}}
.cam-hint{position:absolute;bottom:16px;left:0;right:0;text-align:center;font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);}

/* SCAN PREVIEW (after capture) */
#scanPreview{display:none;width:100%;height:100%;object-fit:cover;}
.retake-btn{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.7);border:1px solid var(--br);color:var(--wh);font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:7px 12px;border-radius:1px;cursor:pointer;}

/* SCAN CONTROLS */
.scan-controls{flex-shrink:0;padding:0 16px 16px;display:flex;flex-direction:column;gap:10px;}
.cam-btn-row{display:flex;gap:10px;align-items:center;}
.shutter{width:64px;height:64px;border-radius:50%;background:var(--r);border:3px solid rgba(232,56,13,.4);cursor:pointer;flex-shrink:0;transition:all .15s;display:flex;align-items:center;justify-content:center;font-size:24px;}
.shutter:active{transform:scale(.92);background:var(--r2);}
.shutter:disabled{background:var(--d3);}
.cam-alt{flex:1;display:flex;flex-direction:column;gap:8px;}
.cam-alt-btn{background:var(--d2);border:1px solid var(--br);color:var(--mt2);font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:10px;border-radius:2px;cursor:pointer;text-align:center;transition:all .15s;}
.cam-alt-btn:active{color:var(--wh);border-color:var(--br2);}

/* SCAN RESULT */
.scan-result{background:var(--d1);border:1px solid var(--br);border-radius:2px;padding:14px;margin:0 16px 10px;}
.sr-food{font-family:var(--font);font-size:22px;font-weight:800;color:var(--wh);margin-bottom:8px;}
.sr-macro-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--br);border-radius:1px;overflow:hidden;margin-bottom:10px;}
.sr-macro{background:var(--d2);padding:10px 8px;text-align:center;}
.sr-macro-val{font-family:var(--font);font-size:20px;font-weight:800;color:var(--wh);}
.sr-macro-unit{font-size:9px;color:var(--mt2);}
.sr-macro-name{font-family:var(--mono);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--mt2);margin-top:2px;}
.sr-extras{display:grid;grid-template-columns:1fr 1fr;gap:6px;font-family:var(--mono);font-size:9px;margin-bottom:10px;}
.sr-extra{background:var(--d3);padding:7px 9px;border-radius:1px;display:flex;justify-content:space-between;}
.sr-extra-name{color:var(--mt2);}
.sr-extra-val{color:var(--wh);}
.sr-note{font-size:11px;color:var(--mt2);line-height:1.5;font-style:italic;border-left:2px solid var(--br2);padding-left:10px;}
.sr-serving{margin-bottom:10px;}
.sr-serving-label{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--mt2);margin-bottom:5px;}
.serving-row{display:flex;align-items:center;gap:10px;}
.serving-val{font-family:var(--font);font-size:20px;font-weight:800;color:var(--wh);min-width:32px;}
.serving-slider{flex:1;}

/* ANALYZING OVERLAY */
#analyzingOverlay{display:none;position:absolute;inset:0;background:rgba(8,8,8,.88);z-index:10;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
#analyzingOverlay.show{display:flex;}
.analyzing-ring{width:64px;height:64px;border-radius:50%;border:2px solid var(--br);border-top-color:var(--r);animation:spin 1s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.analyzing-text{font-family:var(--font);font-size:18px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--wh);}
.analyzing-sub{font-family:var(--mono);font-size:9px;color:var(--mt2);letter-spacing:.1em;text-transform:uppercase;}

/* ─── COACH CHAT ─── */
.coach-wrap{display:flex;flex-direction:column;height:100%;}
.coach-msgs{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:10px;-webkit-overflow-scrolling:touch;}
.coach-msgs::-webkit-scrollbar{display:none;}
.msg{display:flex;flex-direction:column;gap:3px;animation:fadeUp .25s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.msg-who{font-family:var(--mono);font-size:8px;letter-spacing:.15em;text-transform:uppercase;}
.msg.coach .msg-who{color:var(--r);}
.msg.user .msg-who{color:var(--mt2);text-align:right;}
.msg-bubble{padding:10px 13px;border-radius:2px;font-size:13px;line-height:1.6;font-weight:300;}
.msg.coach .msg-bubble{background:var(--d2);border:1px solid var(--br);border-top-left-radius:0;}
.msg.user .msg-bubble{background:rgba(232,56,13,.1);border:1px solid rgba(232,56,13,.2);border-top-right-radius:0;align-self:flex-end;color:var(--wh);}
.thinking-dots{display:flex;gap:5px;padding:11px 13px;background:var(--d2);border:1px solid var(--br);border-radius:2px;border-top-left-radius:0;width:fit-content;}
.thinking-dots span{width:5px;height:5px;border-radius:50%;background:var(--mt2);animation:blink 1.2s infinite;}
.thinking-dots span:nth-child(2){animation-delay:.2s;}
.thinking-dots span:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,80%,100%{opacity:.2;transform:scale(.8);}40%{opacity:1;transform:scale(1);}}
.qprompts{padding:8px 14px;overflow-x:auto;display:flex;gap:6px;scrollbar-width:none;border-top:1px solid var(--br);flex-shrink:0;}
.qprompts::-webkit-scrollbar{display:none;}
.qp{background:var(--d2);border:1px solid var(--br);color:var(--mt2);font-family:var(--mono);font-size:8px;letter-spacing:.04em;padding:7px 10px;cursor:pointer;border-radius:1px;transition:all .15s;white-space:nowrap;flex-shrink:0;}
.qp:active{color:var(--wh);border-color:var(--br2);}
.cin-row{padding:10px 14px;border-top:1px solid var(--br);display:flex;gap:8px;background:var(--bk);flex-shrink:0;}
.cin{flex:1;background:var(--d2);border:1px solid var(--br);color:var(--wh);font-family:var(--body);font-size:13px;padding:10px 12px;border-radius:2px;outline:none;resize:none;height:42px;line-height:1.4;}
.cin:focus{border-color:var(--r);}
.cin::placeholder{color:var(--mt);}
.csend{background:var(--r);border:none;color:#fff;width:42px;height:42px;cursor:pointer;border-radius:2px;font-size:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.csend:disabled{background:var(--d3);}

/* TOAST */
#toast{position:fixed;top:66px;left:50%;transform:translateX(-50%);background:var(--d2);border:1px solid var(--gn);color:var(--gn);font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:8px 16px;border-radius:2px;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
#toast.show{opacity:1;}

/* HYDRATION */
.hcups{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px;}
.cup{width:34px;height:42px;border-radius:2px;border:1px solid var(--br);background:var(--d3);display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;transition:all .2s;}
.cup.filled{background:rgba(74,158,255,.12);border-color:rgba(74,158,255,.35);}

/* PACE RESULT */
.pace-result{text-align:center;padding:18px;background:rgba(232,56,13,.06);border:1px solid rgba(232,56,13,.15);border-radius:2px;margin-top:12px;}
.pr-val{font-family:var(--font);font-size:52px;font-weight:900;color:var(--wh);line-height:1;}
.pr-unit{font-family:var(--mono);font-size:9px;color:var(--mt2);margin-top:4px;letter-spacing:.12em;text-transform:uppercase;}
.pr-extra{font-family:var(--mono);font-size:10px;color:var(--mt2);margin-top:8px;}

/* RACE PREDICT */
.rp-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--br);}
.rp-row:last-child{border-bottom:none;}
.rp-dist{font-family:var(--font);font-size:20px;font-weight:700;color:var(--wh);}
.rp-time{font-family:var(--mono);font-size:13px;color:var(--gn);}
.rp-pace{font-family:var(--mono);font-size:9px;color:var(--mt2);}

/* VO2 GAUGE */
.gauge-wrap{display:flex;align-items:center;gap:16px;padding:10px 0;}
.gauge-ring{position:relative;width:72px;height:72px;flex-shrink:0;}
.gauge-svg{width:72px;height:72px;transform:rotate(-90deg);}
.gauge-bg{fill:none;stroke:var(--d3);stroke-width:6;}
.gauge-fill{fill:none;stroke:var(--r);stroke-width:6;stroke-linecap:round;transition:stroke-dashoffset 1s ease;}
.gauge-center{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--font);font-size:18px;font-weight:900;color:var(--wh);}
.gauge-info{}
.gauge-cat{font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;color:var(--mt2);margin-bottom:4px;}
.gauge-tier{font-size:14px;font-weight:500;color:var(--wh);}
.gauge-desc{font-size:11px;color:var(--mt2);margin-top:3px;line-height:1.4;}

/* ─── PROGRESS / TRENDS ─── */
.trends-chart{height:80px;position:relative;margin:8px 0;}

/* GEAR */
.gear-item{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.gear-item:last-child{border-bottom:none;}
.gear-name{font-size:13px;font-weight:500;color:var(--wh);}
.gear-km{font-family:var(--mono);font-size:11px;}
.gear-bar-wrap{margin-top:4px;}
.gear-bar{height:3px;background:var(--d3);border-radius:2px;overflow:hidden;width:120px;}
.gear-bar-fill{height:100%;border-radius:2px;}

/* SPLITS TABLE */
.splits-t{width:100%;border-collapse:collapse;font-size:12px;}
.splits-t th{font-family:var(--mono);font-size:7px;letter-spacing:.12em;text-transform:uppercase;color:var(--mt2);padding:5px 8px;text-align:left;border-bottom:1px solid var(--br);}
.splits-t td{padding:7px 8px;border-bottom:1px solid rgba(255,255,255,.04);font-family:var(--mono);color:var(--tx);}
.splits-t tr:last-child td{border-bottom:none;}
.pace-hi{color:var(--gn);}

/* MACROS RING */
.macro-rings{display:flex;justify-content:center;gap:20px;padding:12px 0;}
.macro-ring{display:flex;flex-direction:column;align-items:center;gap:6px;}
.macro-ring-svg{width:56px;height:56px;transform:rotate(-90deg);}
.mring-bg{fill:none;stroke:var(--d3);stroke-width:5;}
.mring-fill{fill:none;stroke-width:5;stroke-linecap:round;transition:stroke-dashoffset .7s ease;}
.macro-ring-label{font-family:var(--mono);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--mt2);}
.macro-ring-val{font-family:var(--font);font-size:14px;font-weight:800;color:var(--wh);}

/* INLINE TOOL PANELS */
.tool-panel{display:none;}
.tool-panel.open{display:block;}
.back-row{display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:1px solid var(--br);cursor:pointer;background:none;border-top:none;border-left:none;border-right:none;width:100%;}
.back-lbl{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--mt2);}
.back-title{font-family:var(--font);font-size:15px;font-weight:800;color:var(--wh);letter-spacing:.1em;text-transform:uppercase;}

/* ─── NUTRITION MACROS DISPLAY ─── */
.nutr-summary{background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:14px;margin-bottom:14px;}
.nutr-cal-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:12px;}
.nutr-cal-num{font-family:var(--font);font-size:40px;font-weight:900;color:var(--wh);line-height:1;}
.nutr-cal-label{font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;color:var(--mt2);}
.nutr-cal-goal{font-family:var(--mono);font-size:11px;color:var(--mt2);}

/* FOOD LOG ROWS */
.food-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.food-row:last-child{border-bottom:none;}
.food-name{font-size:12px;color:var(--wh);}
.food-meal-tag{font-family:var(--mono);font-size:8px;color:var(--mt2);}
.food-cal{font-family:var(--mono);font-size:11px;color:var(--or);}
.food-macros{font-family:var(--mono);font-size:8px;color:var(--mt2);}

/* INJURY */
.inj-row{padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.inj-row:last-child{border-bottom:none;}
.inj-part{font-size:13px;font-weight:500;color:var(--r);}
.inj-detail{font-family:var(--mono);font-size:9px;color:var(--mt2);margin-top:2px;}

/* SLEEP HISTORY */
.sleep-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.sleep-row:last-child{border-bottom:none;}
.sleep-hrs{font-family:var(--font);font-size:20px;font-weight:700;color:var(--wh);}
.sleep-qual{font-family:var(--mono);font-size:9px;}

/* CHECKIN HISTORY */
.ci-row{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;}
.ci-date{font-family:var(--mono);font-size:9px;color:var(--mt2);}
.ci-pills{display:flex;gap:5px;}

/* PROFILE SETUP CTA */
.setup-cta{background:rgba(232,56,13,.07);border:1px solid rgba(232,56,13,.2);border-radius:2px;padding:14px;margin-bottom:14px;}
.setup-cta-t{font-family:var(--font);font-size:15px;font-weight:700;color:var(--wh);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;}
.setup-cta-s{font-size:12px;color:var(--mt2);line-height:1.5;}

/* WEEK DOTS */
.wd-row{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:4px 0;}
.wd-row::-webkit-scrollbar{display:none;}
.wd{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:4px;}
.wd-dot{width:38px;height:38px;border-radius:50%;background:var(--d3);border:1px solid var(--br);display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .15s;}
.wd-dot.has{background:rgba(232,56,13,.15);border-color:var(--r);}
.wd-dot.today{outline:2px solid var(--wh);outline-offset:2px;}
.wd-name{font-family:var(--mono);font-size:7px;color:var(--mt2);letter-spacing:.08em;text-transform:uppercase;}

/* PERSONAL BESTS */
.pb-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.pb-row:last-child{border-bottom:none;}
.pb-dist{font-family:var(--font);font-size:20px;font-weight:700;color:var(--wh);}
.pb-time{font-family:var(--mono);font-size:14px;color:var(--gn);}
.pb-date{font-family:var(--mono);font-size:8px;color:var(--mt2);}

/* INTERVAL BUILDER */
.iv-block{background:var(--d2);border:1px solid var(--br);border-radius:2px;padding:12px;margin-bottom:8px;}
.iv-block-header{font-family:var(--font);font-size:13px;font-weight:700;color:var(--wh);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;}
.iv-block-detail{font-family:var(--mono);font-size:10px;color:var(--mt2);line-height:1.6;}

/* SCAN HISTORY */
.scan-hist-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.scan-hist-row:last-child{border-bottom:none;}
.scan-hist-food{font-size:12px;font-weight:500;color:var(--wh);}
.scan-hist-time{font-family:var(--mono);font-size:8px;color:var(--mt2);}
.scan-hist-cal{font-family:var(--mono);font-size:11px;color:var(--or);}

/* CALORIE RING */
.cal-ring-wrap{display:flex;justify-content:center;padding:16px 0 8px;}
.cal-ring{position:relative;width:120px;height:120px;}
.cal-ring-svg{width:120px;height:120px;transform:rotate(-90deg);}
.cal-ring-bg{fill:none;stroke:var(--d3);stroke-width:8;}
.cal-ring-fill{fill:none;stroke:var(--r);stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1s ease;}
.cal-ring-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.cal-ring-num{font-family:var(--font);font-size:26px;font-weight:900;color:var(--wh);line-height:1;}
.cal-ring-label{font-family:var(--mono);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--mt2);}
</style>
</head>
<body>
<div id="app">

<!-- TOPBAR -->
<div id="topbar">
  <div class="logo">APEX<span>.</span></div>
  <div id="topbar-meta">
    <div class="meta-pill live" id="streakPill">0 day streak</div>
    <div class="meta-pill" id="datePill"></div>
  </div>
</div>

<!-- PAGES -->
<div id="pages">

<!-- ══════════════════════════════ HOME ══════════════════════════════ -->
<div class="page active" id="page-home">
  <div class="hero">
    <div class="hero-bg"></div><div class="hero-grid"></div>
    <div class="hero-letter">X</div>
    <div class="hero-content">
      <div class="hero-eye" id="heroPhase">Base Building — Week 1</div>
      <div class="hero-ttl">Run <em>Faster.</em><br>Every Day.</div>
      <div class="hero-sub">Your complete running intelligence system</div>
    </div>
  </div>

  <div class="sg">
    <div class="sc"><div class="sl">Weekly km</div><div class="sv" id="h-wkm">0<span class="su">km</span></div><div class="sd nt" id="h-wkm-d">No runs yet</div></div>
    <div class="sc"><div class="sl">Avg Pace</div><div class="sv" id="h-pace">—<span class="su">/km</span></div><div class="sd nt" id="h-pace-d">This week</div></div>
    <div class="sc"><div class="sl">Readiness</div><div class="sv" id="h-ready">—<span class="su">%</span></div><div class="sd nt" id="h-ready-d">Log check-in</div></div>
    <div class="sc"><div class="sl">Load (TSS)</div><div class="sv" id="h-load">—</div><div class="sd nt">Weekly stress</div></div>
    <div class="sc"><div class="sl">VO2 Max Est.</div><div class="sv" id="h-vo2">—</div><div class="sd nt" id="h-vo2-d">From pace data</div></div>
    <div class="sc"><div class="sl">Total Runs</div><div class="sv" id="h-total">0</div><div class="sd nt" id="h-totalkm">0 km all time</div></div>
  </div>

  <div class="sec">
    <div class="sh"><div class="sh-t">Today's Session</div><button class="sh-a" onclick="nav('training')">Full Plan</button></div>
    <div id="todaySess"><div class="empty-s">No plan yet — ask Coach or generate one in Training</div></div>
  </div>

  <div class="sec">
    <div class="sh"><div class="sh-t">Recent Runs</div><button class="sh-a" onclick="nav('progress')">All Runs</button></div>
    <div id="recentHome"><div class="empty-s">Log your first run in the Log tab</div></div>
  </div>

  <div class="sec">
    <div class="sh"><div class="sh-t">Volume — 8 Weeks</div></div>
    <div class="chart-wrap"><canvas id="weekChart"></canvas></div>
  </div>

  <div class="sec">
    <div class="sh"><div class="sh-t">Activity — Last 28 Days</div></div>
    <div class="streak-g" id="streakGrid"></div>
  </div>

  <div class="sec sec-last">
    <button class="btn btn-r" onclick="nav('log')">+ Log Run</button>
    <div style="margin-top:8px;"><button class="btn btn-g" onclick="openScanner()">Scan Food with AI Camera</button></div>
    <div style="margin-top:8px;"><button class="btn btn-g" onclick="nav('coach')">Ask AI Coach</button></div>
  </div>
</div>

<!-- ══════════════════════════════ LOG ══════════════════════════════ -->
<div class="page" id="page-log">
  <div class="tabs" id="logTabBar">
    <button class="tab active" onclick="logTab('run')">Run</button>
    <button class="tab" onclick="logTab('checkin')">Check-In</button>
    <button class="tab" onclick="logTab('sleep')">Sleep</button>
    <button class="tab" onclick="logTab('nutrition')">Nutrition</button>
    <button class="tab" onclick="logTab('body')">Body</button>
  </div>

  <!-- RUN LOG -->
  <div id="lt-run" class="sec">
    <div class="sh"><div class="sh-t">Log a Run</div></div>
    <div class="fg2">
      <div class="fg"><label>Date</label><input class="fi" type="date" id="l-date"></div>
      <div class="fg"><label>Run Type</label>
        <select class="fi" id="l-type"><option>Easy Run</option><option>Tempo Run</option><option>Long Run</option><option>Interval / Track</option><option>Hill Repeats</option><option>Fartlek</option><option>Recovery Run</option><option>Marathon Pace</option><option>Progression Run</option><option>Race</option></select>
      </div>
      <div class="fg"><label>Distance (km)</label><input class="fi" type="number" step="0.01" placeholder="8.5" id="l-dist"></div>
      <div class="fg"><label>Time (h:mm:ss)</label><input class="fi" type="text" placeholder="0:45:30" id="l-time"></div>
      <div class="fg"><label>Avg Heart Rate</label><input class="fi" type="number" placeholder="148" id="l-hr"></div>
      <div class="fg"><label>Max Heart Rate</label><input class="fi" type="number" placeholder="172" id="l-maxhr"></div>
      <div class="fg"><label>Cadence (spm)</label><input class="fi" type="number" placeholder="172" id="l-cad"></div>
      <div class="fg"><label>Elevation (m)</label><input class="fi" type="number" placeholder="120" id="l-elev"></div>
      <div class="fg"><label>Temp (°C)</label><input class="fi" type="number" placeholder="18" id="l-temp"></div>
      <div class="fg"><label>Humidity (%)</label><input class="fi" type="number" placeholder="65" id="l-humid"></div>
      <div class="fg"><label>Surface</label>
        <select class="fi" id="l-surface"><option>Road</option><option>Trail</option><option>Track</option><option>Treadmill</option><option>Mixed</option><option>Grass</option><option>Sand</option></select>
      </div>
      <div class="fg"><label>Shoes Used</label><input class="fi" type="text" placeholder="Nike Pegasus 41" id="l-shoes"></div>
      <div class="fg s2"><label>RPE — <span id="rpeVal">5 Moderate</span></label>
        <input type="range" min="1" max="10" value="5" id="l-rpe" oninput="document.getElementById('rpeVal').textContent=this.value+' '+['','Very Easy','Easy','Easy-Mod','Moderate','Moderate','Mod-Hard','Hard','Very Hard','Max','Absolute Max'][this.value]">
        <div class="slab"><span>1 Easy</span><span>10 Max</span></div>
      </div>
      <div class="fg s2"><label>Run Feel / Notes</label><textarea class="fi" placeholder="Legs felt heavy at km 5, breathing controlled, strong finish..." id="l-notes"></textarea></div>
    </div>
    <div class="brow">
      <button class="btn btn-r" onclick="logRun(true)" id="logRunBtn">Save + AI Analysis</button>
    </div>
    <div id="logStatus" style="font-family:var(--mono);font-size:9px;color:var(--mt2);margin-top:8px;"></div>
  </div>

  <!-- DAILY CHECK-IN -->
  <div id="lt-checkin" class="sec" style="display:none">
    <div class="sh"><div class="sh-t">Daily Check-In</div></div>
    <div class="fg1">
      <div class="fg"><label>Mood — <span id="moodLbl">OK</span></label>
        <input type="range" min="1" max="5" value="3" id="ci-mood" oninput="sliderLbl('ci-mood','moodLbl',['Very Low','Low','OK','Good','Great'])">
        <div class="slab"><span>1</span><span>5</span></div>
      </div>
      <div class="fg"><label>Energy — <span id="energyLbl">OK</span></label>
        <input type="range" min="1" max="5" value="3" id="ci-energy" oninput="sliderLbl('ci-energy','energyLbl',['Exhausted','Low','OK','Good','High'])">
        <div class="slab"><span>1</span><span>5</span></div>
      </div>
      <div class="fg"><label>Stress — <span id="stressLbl">Moderate</span></label>
        <input type="range" min="1" max="5" value="3" id="ci-stress" oninput="sliderLbl('ci-stress','stressLbl',['None','Low','Moderate','High','Very High'])">
        <div class="slab"><span>1 None</span><span>5 High</span></div>
      </div>
      <div class="fg"><label>Motivation — <span id="motivLbl">OK</span></label>
        <input type="range" min="1" max="5" value="3" id="ci-motiv" oninput="sliderLbl('ci-motiv','motivLbl',['None','Low','OK','Good','Pumped'])">
        <div class="slab"><span>1</span><span>5</span></div>
      </div>
    </div>
    <div class="fg2" style="margin-top:10px;">
      <div class="fg"><label>Muscle Soreness</label>
        <select class="fi" id="ci-sor"><option>None</option><option>Mild</option><option>Moderate</option><option>Severe</option></select>
      </div>
      <div class="fg"><label>Leg Feel</label>
        <select class="fi" id="ci-legs"><option>Fresh</option><option>Normal</option><option>Tired</option><option>Dead</option></select>
      </div>
      <div class="fg"><label>Pain/Injury noted</label><input class="fi" type="text" placeholder="Left knee, mild..." id="ci-pain"></div>
      <div class="fg"><label>Appetite</label>
        <select class="fi" id="ci-app"><option>Normal</option><option>High</option><option>Low</option><option>None</option></select>
      </div>
      <div class="fg s2"><label>Today's notes</label><textarea class="fi" placeholder="How are you feeling today overall?" id="ci-notes"></textarea></div>
    </div>
    <button class="btn btn-r" onclick="saveCheckin()" style="margin-top:12px;">Save Check-In</button>
    <div class="divl"></div>
    <div class="sh"><div class="sh-t">Check-In History</div></div>
    <div id="ciHistory"><div class="empty-s">No check-ins yet</div></div>
  </div>

  <!-- SLEEP -->
  <div id="lt-sleep" class="sec" style="display:none">
    <div class="sh"><div class="sh-t">Sleep Log</div></div>
    <div class="fg2">
      <div class="fg"><label>Bedtime</label><input class="fi" type="time" id="sl-bed"></div>
      <div class="fg"><label>Wake time</label><input class="fi" type="time" id="sl-wake"></div>
      <div class="fg"><label>HRV (ms)</label><input class="fi" type="number" placeholder="65" id="sl-hrv"></div>
      <div class="fg"><label>Resting HR</label><input class="fi" type="number" placeholder="52" id="sl-rhr"></div>
      <div class="fg s2"><label>Quality — <span id="sleepQlbl">OK</span></label>
        <input type="range" min="1" max="5" value="3" id="sl-qual" oninput="sliderLbl('sl-qual','sleepQlbl',['Terrible','Poor','OK','Good','Excellent'])">
        <div class="slab"><span>1</span><span>5</span></div>
      </div>
      <div class="fg s2"><label>Notes (disruptions, dreams, room temp)</label><input class="fi" type="text" placeholder="Woke up at 3am, vivid dreams..." id="sl-notes"></div>
    </div>
    <button class="btn btn-r" onclick="saveSleep()" style="margin-top:12px;">Save Sleep Data</button>
    <div class="divl"></div>
    <div class="sh"><div class="sh-t">Sleep History</div></div>
    <div id="sleepHist"><div class="empty-s">No sleep data yet</div></div>
  </div>

  <!-- NUTRITION -->
  <div id="lt-nutrition" class="sec" style="display:none">
    <div class="sh"><div class="sh-t">Today's Nutrition</div><button class="sh-a" onclick="openScanner()">AI Scan Food</button></div>
    <div class="nutr-summary" id="nutrSummary">
      <div class="nutr-cal-row">
        <div><div class="nutr-cal-num" id="nt-cal">0</div><div class="nutr-cal-label">kcal today</div></div>
        <div style="text-align:right"><div class="nutr-cal-goal">Goal: <span id="nt-cal-goal">2200</span> kcal</div><div id="nt-cal-rem" style="font-family:var(--mono);font-size:11px;color:var(--gn);margin-top:2px;">2200 remaining</div></div>
      </div>
      <div class="cal-ring-wrap">
        <div class="cal-ring">
          <svg class="cal-ring-svg" viewBox="0 0 120 120">
            <circle class="cal-ring-bg" cx="60" cy="60" r="52"/>
            <circle class="cal-ring-fill" id="calRingFill" cx="60" cy="60" r="52" stroke-dasharray="327" stroke-dashoffset="327"/>
          </svg>
          <div class="cal-ring-center">
            <div class="cal-ring-num" id="calRingPct">0%</div>
            <div class="cal-ring-label">of goal</div>
          </div>
        </div>
