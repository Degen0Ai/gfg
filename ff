      <div class="sr-extra"><span class="sr-extra-name">Sat. Fat</span><span class="sr-extra-val">${r.saturated_fat||0}g</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Cholesterol</span><span class="sr-extra-val">${r.cholesterol||0}mg</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Potassium</span><span class="sr-extra-val">${r.potassium||0}mg</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Vitamin C</span><span class="sr-extra-val">${r.vitamin_c||0}mg</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Iron</span><span class="sr-extra-val">${r.iron||0}mg</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Calcium</span><span class="sr-extra-val">${r.calcium||0}mg</span></div>
      <div class="sr-extra"><span class="sr-extra-name">Glycemic Idx</span><span class="sr-extra-val">${r.glycemic_index||'—'}</span></div>
    </div>
    ${r.running_tip?`<div class="sr-note" style="border-color:var(--r);margin-bottom:10px;"><strong style="color:var(--r);">Running note:</strong> ${r.running_tip}</div>`:''}
    ${r.note?`<div class="sr-note">${r.note}</div>`:''}`;

  document.getElementById('scanActionBtns').style.display='block';
}

function addScannedFood(){
  if(!S.currentScan)return;
  addFood({
    name:S.currentScan.name,cal:S.currentScan.cal,prot:S.currentScan.prot,
    carb:S.currentScan.carb,fat:S.currentScan.fat,fiber:S.currentScan.fiber||0,
    sugar:S.currentScan.sugar||0,sodium:S.currentScan.sodium||0,
    meal:'Snack',time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})
  });
  toast('Added to food log ✓');
  closeScanner();
  nav('log');logTab('nutrition');
}

function typeFood(){
  closeScanner();
  nav('log');logTab('nutrition');
  document.getElementById('nf-name').focus();
}

