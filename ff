function calcPace(){
  const d=parseFloat(document.getElementById('tp-dist').value);
  const t=document.getElementById('tp-time').value;
  const s=timeToSecs(t);if(!s||!d){toast('Enter distance and time');return;}
  const pps=s/d;const spd=3600/pps;
  document.getElementById('tp-result').innerHTML=`
    <div class="pace-result">
      <div class="pr-val">${fmtPace(pps)}</div><div class="pr-unit">per kilometer</div>
      <div class="pr-extra">Speed: ${spd.toFixed(2)} km/h · Total: ${secsToTime(s)}</div>
    </div>
    <div style="margin-top:12px;font-family:var(--mono);font-size:9px;color:var(--mt2);">1km splits at this pace:</div>
    <table class="splits-t" style="margin-top:6px;"><thead><tr><th>km</th><th>Split</th><th>Cumulative</th></tr></thead><tbody>
      ${Array.from({length:Math.ceil(d)},(_,i)=>`<tr><td>${i+1}</td><td class="pace-hi">${fmtPace(pps)}</td><td>${secsToTime(Math.round(pps*(i+1)))}</td></tr>`).join('')}
    </tbody></table>`;
}

function calcSplits(){
  const dist=parseFloat(document.getElementById('sp-dist').value);
  const time=document.getElementById('sp-time').value;
  const strat=document.getElementById('sp-strat').value;
  const total=timeToSecs(time);if(!total){toast('Enter goal time');return;}
  const basePace=total/dist;
  const n=Math.ceil(dist);
  const splits=Array.from({length:n},(_,i)=>{
    let p=basePace;
    if(strat==='neg')p=basePace+(n/2-i)*5/n;
    if(strat==='pos')p=basePace-(n/2-i)*5/n;
    return p;
  });
  let cum=0;
  document.getElementById('sp-result').innerHTML=`<table class="splits-t"><thead><tr><th>km</th><th>Target Pace</th><th>Split Time</th><th>Cumulative</th></tr></thead><tbody>
    ${splits.map((p,i)=>{cum+=p;return`<tr><td>${i+1}</td><td class="pace-hi">${fmtPace(p)}</td><td>${secsToTime(Math.round(p))}</td><td>${secsToTime(Math.round(cum))}</td></tr>`;}).join('')}
  </tbody></table>`;
}

function calcTSS(){
  const dur=parseInt(document.getElementById('ts-dur').value);
  const hr=parseInt(document.getElementById('ts-hr').value);
  const max=parseInt(document.getElementById('ts-max').value);
  const lt=parseInt(document.getElementById('ts-lt').value)||Math.round(max*0.88);
  if(!dur||!hr||!max){toast('Fill in all fields');return;}
  const hrss=(hr/lt)*100;
  const tss=Math.round((dur*hrss*hrss)/(60*100));
  const load=tss<50?'Low — fully recoverable in 24h':tss<100?'Moderate — 1–2 days to recover':tss<150?'High — 2–3 days':tss<200?'Very High — 3+ days':'Extreme — 4+ days needed';
  document.getElementById('ts-result').innerHTML=`<div class="pace-result"><div class="pr-val">${tss}</div><div class="pr-unit">Training Stress Score</div><div class="pr-extra">${load}</div></div>`;
}

function calcCalBurn(){
  const wt=parseFloat(document.getElementById('cb-wt').value)||74;
  const dist=parseFloat(document.getElementById('cb-dist').value);
  const pace=document.getElementById('cb-pace').value;
  if(!dist){toast('Enter distance');return;}
  const cal=Math.round(wt*dist*1.04);
  const dur=paceSecs(dist,pace)||0;
  document.getElementById('cb-result').innerHTML=`<div class="pace-result"><div class="pr-val">${cal}</div><div class="pr-unit">kcal burned</div><div class="pr-extra">${dist}km at ${wt}kg · ${dur?Math.round(dur*dist/60)+' min':'—'}<br>Fat burned: ~${(cal*0.35/9).toFixed(1)}g · Carbs: ~${(cal*0.65/4).toFixed(0)}g</div></div>`;
}

function calcSweat(){
  const pre=parseFloat(document.getElementById('sw-pre').value);
  const post=parseFloat(document.getElementById('sw-post').value);
  const fluid=parseInt(document.getElementById('sw-fluid').value)||0;
  const dur=parseInt(document.getElementById('sw-dur').value)||60;
  if(!pre||!post){toast('Enter both weights');return;}
  const loss=(pre-post)*1000+fluid;
  const rate=Math.round(loss/(dur/60));
  document.getElementById('sw-result').innerHTML=`<div class="pace-result"><div class="pr-val">${loss}ml</div><div class="pr-unit">total fluid loss</div><div class="pr-extra">Sweat rate: ${rate} ml/hour<br>Per km: ~${Math.round(rate/10)} ml<br>Drink ~${Math.round(rate/4)} ml every 15 min during runs</div></div>`;
}

function calcStride(){
  const cad=parseInt(document.getElementById('str-cad').value);
  const pace=document.getElementById('str-pace').value;
  if(!cad){toast('Enter cadence');return;}
  const ps=paceSecs(1,pace)||300;
  const speedMs=1000/ps;
  const strideLen=(speedMs*60/cad)*100;
  const ideal=cad<170?'Increase cadence toward 170-180 for better efficiency':'Good cadence range';
  document.getElementById('str-result').innerHTML=`<div class="pace-result"><div class="pr-val">${strideLen.toFixed(0)}<span style="font-size:20px">cm</span></div><div class="pr-unit">stride length</div><div class="pr-extra">${cad} spm · ${ideal}</div></div>`;
}

function calcLTHR(){
  const lt=parseInt(document.getElementById('lt-hr').value);
  const max=parseInt(document.getElementById('lt-max').value)||Math.round(lt/0.88);
  if(!lt){toast('Enter LTHR');return;}
  const zones=[['Z1 Recovery',.75,.85],['Z2 Aerobic',.85,.89],['Z3 Tempo',.89,.94],['Z4 Threshold',.94,1.0],['Z5 VO2 Max',1.0,1.06]];
  document.getElementById('lt-result').innerHTML=`<div style="margin-bottom:8px;font-family:var(--mono);font-size:9px;color:var(--mt2);">LTHR: ${lt} bpm · Zones based on % LTHR</div>`+zones.map(([n,lo,hi])=>`<div class="rp-row"><div class="rp-dist" style="font-size:14px;">${n}</div><div class="rp-time">${Math.round(lt*lo)}–${Math.round(lt*hi)} bpm</div></div>`).join('');
}

function calcBMI(){
  const wt=parseFloat(document.getElementById('bmi-wt').value);
  const ht=parseFloat(document.getElementById('bmi-ht').value)/100;
  if(!wt||!ht){toast('Enter weight and height');return;}
  const bmi=(wt/(ht*ht)).toFixed(1);
  const rw=Math.round(22*(ht*ht));
  const cat=bmi<18.5?'Underweight':bmi<25?'Normal':bmi<30?'Overweight':'Obese';
  document.getElementById('bmi-result').innerHTML=`
    <div class="pace-result"><div class="pr-val">${bmi}</div><div class="pr-unit">BMI · ${cat}</div><div class="pr-extra">Optimal race weight estimate: ${rw}kg<br>Current surplus: ${(wt-rw)>0?'+'+(wt-rw).toFixed(1):(wt-rw).toFixed(1)} kg</div></div>
    <div style="font-family:var(--mono);font-size:9px;color:var(--mt2);margin-top:10px;line-height:1.5;">Note: Race weight is an estimate only. Performance depends on many factors beyond weight. Never pursue extreme weight loss for sport.</div>`;
}

